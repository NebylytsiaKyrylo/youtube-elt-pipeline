        <mxCell id="PrIECbW2FLJ77NGQQZM7-3" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=20;fillColor=default;align=center;fontStyle=1" value="Orchestration Apache Airflow" vertex="1">
