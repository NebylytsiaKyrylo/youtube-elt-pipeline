        <mxCell id="LriGtjPIddiLVAorbOpY-1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=18;horizontal=1;" value="&lt;b&gt;Schéma :&lt;/b&gt;&amp;nbsp;staging&lt;b&gt;&lt;br&gt;Type d&#39;objet :&lt;/b&gt; Table&lt;br&gt;&lt;b&gt;Type de colonnes :&lt;/b&gt;&amp;nbsp;TEXT&lt;br&gt;&lt;br&gt;&lt;b&gt;Stratégie de chargement :&lt;/b&gt;&lt;br&gt;• Traitement par batch&lt;br&gt;• Full load&lt;br&gt;• Truncate &amp;amp; Insert&lt;br&gt;&lt;br&gt;&lt;b&gt;Transformations :&lt;/b&gt;&lt;br&gt;Aucune (miroir brut de l&#39;API)&lt;br&gt;&lt;br&gt;&lt;b&gt;Modèle de données :&lt;/b&gt;&lt;br&gt;Aucun (as-is)&lt;br&gt;&lt;br&gt;&lt;b&gt;Grain :&lt;/b&gt; une ligne par vidéo" vertex="1">
          <mxGeometry height="340" width="238" x="634.5" y="267" as="geometry" />
        </mxCell>
        <mxCell id="qLx4dXdiwCbFH0wvxEzs-1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=18;" value="&lt;b&gt;Schéma :&lt;/b&gt;&amp;nbsp;core&lt;b&gt;&lt;br&gt;Type d&#39;objet :&lt;/b&gt; Tables&lt;br&gt;&lt;br&gt;&lt;b&gt;Stratégie de chargement :&lt;/b&gt;&lt;br&gt;• Traitement par batch&lt;br&gt;• UPSERT (ON CONFLICT)&lt;br&gt;• Idempotent (rejouable)&lt;br&gt;&lt;br&gt;&lt;b&gt;Transformations :&lt;/b&gt;&lt;br&gt;• Typage (TEXT → typé)&lt;br&gt;• Normalisation&lt;br&gt;• Colonnes dérivées&lt;br&gt;• Soft delete&lt;br&gt;&lt;br&gt;&lt;b&gt;Modèle :&lt;/b&gt; Star Schema Kimball&lt;br&gt;• &lt;b&gt;dim_channel&lt;/b&gt; (SCD1)&lt;br&gt;• &lt;b&gt;dim_video&lt;/b&gt; (SCD1 + soft delete)&lt;br&gt;• &lt;b&gt;fct_video_daily_snapshot&lt;/b&gt;" vertex="1">
          <mxGeometry height="395" width="274" x="1006" y="262" as="geometry" />
        </mxCell>
        <mxCell id="pqY4Tcg-yKXxvN4xxC2G-1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=18;" value="&lt;b&gt;Schéma :&lt;/b&gt; marts&lt;br&gt;&lt;b&gt;Type d&#39;objet :&lt;/b&gt; Tables&lt;br&gt;&lt;br&gt;&lt;b&gt;Stratégie :&lt;/b&gt;&lt;br&gt;• Reconstruction quotidienne&lt;br&gt;• DROP + CTAS (full refresh)&lt;br&gt;• Pas de PK / FK&amp;nbsp;&lt;br&gt;&lt;br&gt;&lt;b&gt;Transformations :&lt;/b&gt;&lt;br&gt;• Agrégations&lt;br&gt;• Logique métier&lt;br&gt;• Window functions&lt;br&gt;• Buckets (taille, durée)&lt;br&gt;&lt;br&gt;&lt;b&gt;Modèle :&lt;/b&gt; Tables plates dénormalisées&lt;br&gt;&lt;br&gt;&lt;b&gt;Dénombrement :&lt;/b&gt;&lt;br&gt;• 7 marts chaîne&lt;br&gt;• 2 marts vidéo&lt;br&gt;• 1 mart format (durée)" vertex="1">
          <mxGeometry height="395" width="261" x="1399" y="257" as="geometry" />
        </mxCell>
