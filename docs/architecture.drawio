        </mxCell>
        <mxCell id="PrIECbW2FLJ77NGQQZM7-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Helvetica;fontSize=17;fontColor=default;" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Anthropic Sans&amp;quot;, system-ui, &amp;quot;Segoe UI&amp;quot;, Roboto, Helvetica, Arial, sans-serif; background-color: rgb(253, 253, 252);&quot;&gt;&lt;font&gt;&lt;b&gt;Contrôle&lt;/b&gt; de complétude et de cohérence métier : chaque mart est alimenté et les indicateurs calculés respectent leurs intervalles de validité définis.&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-family: &amp;quot;Anthropic Sans&amp;quot;, system-ui, &amp;quot;Segoe UI&amp;quot;, Roboto, Helvetica, Arial, sans-serif; background-color: rgb(253, 253, 252);&quot;&gt;Si un mart est vide ou qu&#39;un score dépasse sa borne, c&#39;est le signe d&#39;un bug dans la logique SQL.&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="281" x="1378" y="871" as="geometry" />
